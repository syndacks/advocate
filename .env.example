# Copy this file to .env and fill in values before running the stack.
# Never commit .env to version control.

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=advocate
POSTGRES_USER=advocate
POSTGRES_PASSWORD=advocate

# Application database (separate from Prefect's database to avoid alembic_version collision)
# Prefect uses the 'advocate' database; the app uses 'advocate_app'.
# Create advocate_app manually after dev-up:
#   docker exec advocate-postgres-1 psql -U advocate -d advocate -c "CREATE DATABASE advocate_app OWNER advocate;"
DATABASE_URL=postgresql+asyncpg://advocate:advocate@localhost:5433/advocate_app

# ── Redis (ephemeral coordination only) ───────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── MinIO / S3-compatible Object Storage ──────────────────────────────────────
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_REGION=us-east-1
S3_BUCKET=advocate-evidence
S3_ARTIFACTS_BUCKET=advocate-artifacts

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ── Prefect ───────────────────────────────────────────────────────────────────
PREFECT_API_URL=http://localhost:4200/api

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Required for LLM extraction and embedding tasks.
OPENAI_API_KEY=sk-...

# Model used for bounded LLM extraction (must support structured JSON output)
OPENAI_EXTRACTION_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
APP_VERSION=0.1.0
LOG_LEVEL=INFO

# API host/port
API_HOST=0.0.0.0
API_PORT=8000

# Internal worker endpoint (used by Prefect flows to trigger re-processing)
WORKER_BASE_URL=http://localhost:8001
